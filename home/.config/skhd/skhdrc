# change window focus within space
alt + cmd - j : yabai -m window --focus south
alt + cmd - k : yabai -m window --focus north 
alt + cmd - h : yabai -m window --focus west
alt + cmd - l : yabai -m window --focus east

# rotate layout
alt + shift - r : yabai -m space --rotate 270
alt + shift - y : yabai -m space --mirror y-axis
alt + shift - x : yabai -m space --mirror x-axis
alt + shift - f : yabai -m window --toggle float --grid 9:4:1:1:2:7

# window resizing
alt + cmd - return : yabai -m window --toggle zoom-fullscreen
alt + cmd - space : yabai -m space --balance

# swap windows
alt + shift - j : yabai -m window --swap south
alt + shift - k : yabai -m window --swap north
alt + shift - h : yabai -m window --swap west
alt + shift - l : yabai -m window --swap east

# move window and split
alt + ctrl - j : yabai -m window --warp south
alt + ctrl - k : yabai -m window --warp north
alt + ctrl - h : yabai -m window --warp west
alt + ctrl - l : yabai -m window --warp east

# move window to space
alt + ctrl + cmd - p : yabai -m window --space prev
alt + ctrl + cmd - n : yabai -m window --space next

# space control (requires SIP to be partially disabled)
# alt + ctrl + cmd - home : yabai -m space --create
# alt + ctrl + cmd - end : yabai -m space --destroy
