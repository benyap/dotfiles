{
  "workbench.colorTheme": "One Dark Pro",
  "workbench.editor.restoreViewState": false,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.integrated.defaultProfile.osx": "fish",
  "editor.fontFamily": "Menlo, 'Courier New', monospace",
  "editor.codeLens": false,
  "editor.formatOnSave": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.openEditors.visible": 0,
  "prettier.proseWrap": "always",
  "files.associations": {
    "fish_variables": "fish",
    ".env": "ini",
    ".env.uat": "ini",
    ".env.dev": "ini",
    ".env.template": "ini"
  },
  "workbench.iconTheme": "material-icon-theme",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "terminal.external.osxExec": "kitty.app",
  "terminal.integrated.bellDuration": 10000,
  "editor.tabSize": 2,
  "terminal.integrated.fontFamily": "'MesloLGS Nerd Font', Menlo, 'Courier New', monospace",
  "editor.renderControlCharacters": true,
  "editor.minimap.enabled": false,
  "editor.suggest.showWords": false,
  "auto-close-tag.disableOnLanguage": ["typescript"],
  "todohighlight.keywords": [
    "TODO:",
    "FIXME:",
    {
      "text": "TEMP:",
      "color": "black",
      "backgroundColor": "cyan",
      "overviewRulerColor": "cyan"
    },
    {
      "text": "HACK:",
      "color": "black",
      "backgroundColor": "lightpink",
      "overviewRulerColor": "lightpink"
    }
  ],
  "json.maxItemsComputed": 50000,
  "window.newWindowDimensions": "maximized",
  "[python]": {
    "editor.defaultFormatter": "ms-python.python"
  },
  "[xml]": {
    "editor.defaultFormatter": "DotJoshJohnson.xml"
  },
  "[typescriptreact]": {
    "tailwindCSS.experimental.classRegex": [
      // Matches with multiline object properties such as
      // {
      //    inputClass:
      //      "bg-gray-200 text-gray-800 " +
      //      "hover:bg-gray-300 active:bg-gray-300",
      // }
      //
      ["\\s+[a-zA-Z]+Class:[\\s\\n]+\"([^,]+)\"+"],
      // For matching HeadlessUI's transition and custom transition props
      ["(?:enter|leave)(?:From|To|Duration)?=\\s*(?:\"|')([^(?:\"|')]*)"]
    ]
  },
  // -- Vim settings
  "vim.highlightedyank.enable": true,
  "vim.smartRelativeLine": true,
  "vim.hlsearch": true,
  "vim.camelCaseMotion.enable": true,
  "vim.sneak": true,
  "vim.sneakReplacesF": true,
  "vim.useSystemClipboard": true,
  "vim.easymotion": true,
  "vim.visualstar": true,
  "vim.showMarksInGutter": true,
  // -- Vim remaps
  "vim.leader": "<space>",
  "vim.normalModeKeyBindingsNonRecursive": [
    // Show whichkey
    {
      "before": ["<space>"],
      "commands": ["whichkey.show"]
    },
    // Disable search highlight
    {
      "before": ["<C-n>"],
      "commands": [":nohl"]
    },
    // Indentation
    {
      "before": ["<tab>"],
      "commands": ["editor.action.indentLines"]
    },
    {
      "before": ["<S-tab>"],
      "commands": ["editor.action.outdentLines"]
    },
    // Undo / redo
    {
      "before": ["u"],
      "commands": ["undo"]
    },
    {
      "before": ["<C-r>"],
      "commands": ["redo"]
    },
    // Definition nagivation
    {
      "before": ["g", "D"],
      "commands": ["editor.action.peekDefinition"]
    },
    {
      "before": ["g", "r"],
      "commands": ["editor.action.referenceSearch.trigger"]
    },
    {
      "before": ["g", "b"],
      "commands": ["workbench.action.navigateBack"]
    },
    {
      "before": ["g", "p"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["g", "P"],
      "commands": ["editor.action.marker.prev"]
    },
    {
      "before": ["g", "R"],
      "commands": ["editor.action.rename"]
    },
    // Editor groups
    {
      "before": ["<S-h>"],
      "commands": ["workbench.action.focusNextGroup"]
    },
    {
      "before": ["<S-l>"],
      "commands": ["workbench.action.focusNextGroup"]
    },
    {
      "before": ["<S-j>"],
      "commands": ["workbench.action.focusBelowGroup"]
    },
    {
      "before": ["<S-k>"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["<C-h>"],
      "commands": ["workbench.action.moveEditorToPreviousGroup"]
    },
    {
      "before": ["<C-l>"],
      "commands": ["workbench.action.moveEditorToNextGroup"]
    },
    {
      "before": ["<C-j>"],
      "commands": ["workbench.action.moveEditorToBelowGroup"]
    },
    {
      "before": ["<C-k>"],
      "commands": ["workbench.action.moveEditorToAboveGroup"]
    },
    {
      "before": ["<C-w>"],
      "commands": ["workbench.action.closeActiveEditor"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    // Show whichkey
    {
      "before": ["<C-space>"],
      "commands": ["whichkey.show"]
    },
    // Copy lines
    {
      "before": ["<C-j>"],
      "commands": ["editor.action.copyLinesUpAction"]
    },
    {
      "before": ["<C-k>"],
      "commands": ["editor.action.copyLinesDownAction"]
    },
    // Indentation
    {
      "before": ["<tab>"],
      "commands": ["editor.action.indentLines"]
    },
    {
      "before": ["<S-tab>"],
      "commands": ["editor.action.outdentLines"]
    }
  ],
  // -- Vim whichkey
  "whichkey.bindings": [
    {
      "key": "p",
      "name": "Command palette",
      "commands": ["workbench.action.showCommands"]
    },
    {
      "key": "c",
      "name": "Save and close buffer",
      "commands": [
        "workbench.action.files.save",
        "workbench.action.closeActiveEditor"
      ]
    },
    {
      "key": "s",
      "name": "Save buffer",
      "commands": ["workbench.action.files.save"]
    },
    {
      "key": "b",
      "name": "Show all buffers",
      "commands": ["workbench.action.showAllEditors"]
    },
    {
      "key": "f",
      "name": "Quick open file",
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "key": "e",
      "name": "File explorer",
      "commands": ["workbench.explorer.fileView.focus"]
    },
    {
      "key": "t",
      "name": "Open new terminal in panel",
      "commands": ["workbench.action.terminal.new"]
    },
    {
      "key": "T",
      "name": "Open new terminal in editor",
      "commands": [
        "workbench.action.terminal.new",
        "workbench.action.terminal.focus",
        "workbench.action.terminal.moveToEditor"
      ]
    },
    {
      "key": "/",
      "name": "Toggle comment",
      "commands": ["editor.action.commentLine"]
    },
    {
      "key": "E",
      "name": "Toggle sidebar",
      "commands": ["workbench.action.toggleSidebarVisibility"]
    },
    {
      "key": "P",
      "name": "Format document",
      "commands": [
        "editor.action.formatDocument",
        "prettier.forceFormatDocument"
      ]
    },
    // File operations
    {
      "key": "F",
      "name": "+ File",
      "bindings": [
        {
          "key": "w",
          "name": "Open active in new window",
          "commands": ["workbench.action.files.showOpenedFileInNewWindow"]
        },
        {
          "key": "n",
          "name": "New file",
          "commands": ["workbench.action.files.newUntitledFile"]
        },
        {
          "key": "l",
          "name": "Change file language",
          "type": "command",
          "command": "workbench.action.editor.changeLanguageMode"
        },
        {
          "key": "e",
          "name": "Show file in explorer",
          "type": "command",
          "command": "workbench.files.action.showActiveFileInExplorer"
        },
        {
          "key": "r",
          "name": "Rename file",
          "commands": [
            "workbench.files.action.showActiveFileInExplorer",
            "renameFile"
          ]
        },
        {
          "key": "S",
          "name": "Save all files",
          "command": "workbench.action.files.saveAll"
        },
        {
          "key": "R",
          "name": "Open recent",
          "command": "workbench.action.openRecent"
        }
      ]
    },
    // Window operations
    {
      "key": "w",
      "name": "+ Window",
      "bindings": [
        {
          "key": "s",
          "name": "Split editor below",
          "type": "command",
          "command": "workbench.action.splitEditorDown"
        },
        {
          "key": "v",
          "name": "Split editor right",
          "type": "command",
          "command": "workbench.action.splitEditor"
        },
        {
          "key": "m",
          "name": "Maximize editor group",
          "type": "command",
          "command": "workbench.action.minimizeOtherEditors"
        },
        {
          "key": "M",
          "name": "Maximize editor group and hide side bar",
          "type": "command",
          "command": "workbench.action.maximizeEditor"
        },
        {
          "key": "=",
          "name": "Reset editor group sizes",
          "type": "command",
          "command": "workbench.action.evenEditorWidths"
        },
        {
          "key": "z",
          "name": "Combine all editors",
          "type": "command",
          "command": "workbench.action.joinAllGroups"
        },
        {
          "key": "d",
          "name": "Close editor group",
          "type": "command",
          "command": "workbench.action.closeEditorsInGroup"
        },
        {
          "key": "u",
          "name": "Reopen last closed editor",
          "type": "command",
          "command": "workbench.action.reopenClosedEditor"
        },
        {
          "key": "X",
          "name": "Close all editor groups",
          "type": "command",
          "command": "workbench.action.closeAllGroups"
        }
      ]
    },
    {
      "key": "R",
      "name": "Reload window",
      "commands": ["workbench.action.reloadWindow"]
    },
    {
      "key": "?",
      "name": "Search keybindings",
      "commands": ["whichkey.searchBindings"]
    }
  ],
  "window.zoomLevel": 1
}
